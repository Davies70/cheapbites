  name: string;
  category: string;
  priceForTwo?: number;
  address?: string;
  id: string;
  rating?: number;
  reviewCount?: number;
  distance?: number;
  images?: { prefix: string; suffix: string };
}

export default function TrendingPlaceCard({
  name,
  category,
  address,
  id,
  rating,
  reviewCount,
  distance,
  images,
}: TrendingPlaceCardProps) {
