"use client";

import { signIn } from "next-auth/react";
import { Button } from "@/components/ui/button";
import { X, Utensils } from "lucide-react";

interface SignInOverlayProps {
  onClose: () => void;
  onSuccess: () => void;
}

export default function SignInOverlay({
  onClose,
  onSuccess,
}: SignInOverlayProps) {
  const handleGoogleSignIn = async () => {
    try {
      // callbackUrl ensures they return exactly to the page they were on
      await signIn("google", { callbackUrl: window.location.href });
    } catch (error) {
      console.error("Failed to sign in with Google:", error);
    }
  };

  return (
    <div className="fixed inset-0 z-[9999] flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 animate-in fade-in duration-200">
      <div className="bg-white rounded-3xl shadow-2xl relative max-w-sm w-full p-8 text-center animate-in zoom-in-95 duration-200">
        {/* Close Button */}
        <Button
          variant="ghost"
          size="icon"
          className="absolute top-3 right-3 rounded-full hover:bg-gray-100"
          onClick={onClose}
        >
          <X className="h-5 w-5 text-gray-500" />
        </Button>

        {/* Foodie Icon */}
        <div className="mx-auto w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-6 text-primary">
          <Utensils className="w-8 h-8" />
        </div>

        {/* Text Content */}
        <h2 className="text-2xl font-bold mb-2 text-gray-900">
          Save your favorites
        </h2>
        <p className="text-sm text-gray-500 mb-8 leading-relaxed">
          Sign in to save this place, track your visits, and get personalized
          cheap bite recommendations.
        </p>

        {/* Action Button */}
        <Button
          onClick={handleGoogleSignIn}
          size="lg"
          className="w-full flex items-center justify-center space-x-3 text-base h-12 rounded-xl"
        >
          <svg className="w-5 h-5" viewBox="0 0 24 24">
            <path
              fill="currentColor"
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            />
