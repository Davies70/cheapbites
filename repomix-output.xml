  japanese: '4bf58dd8d48988d111941735', // Japanese Restaurant
  chinese: '4bf58dd8d48988d145941735', // Chinese Restaurant
  default: '4d4b7105d754a06374d81259', // General Food & Dining
};

const getCategoryIds = (
  quizAnwser: string,
